# The Time Sphere — Environment Variables
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Anthropic API key for generate-city-data.js
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Ticketmaster Discovery API (free, 5000 calls/day)
# Sign up at developer.ticketmaster.com → My Apps → Create App → copy "Consumer Key"
TICKETMASTER_API_KEY=

# Optional: Eventbrite API (free, 1000 calls/hour)
# Sign up at eventbrite.com/account-settings/apps → Create API Key
EVENTBRITE_API_KEY=

# Optional: Viator Partner API (separate from affiliate pid=P00295924)
# Request access at partners.viator.com → API access
VIATOR_API_KEY=
